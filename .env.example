# AVAR — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# Claude API (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Cohere API (Command A reasoning model)
COHERE_API_KEY=your_cohere_api_key_here

# Server
PORT=3001
NODE_ENV=development

# Auth (OAuth2 / SSO)
AUTH_SECRET=your_auth_secret_here
AUTH_ISSUER=https://your-auth-provider.com
AUTH_CLIENT_ID=your_client_id
AUTH_CLIENT_SECRET=your_client_secret

# Search backends (add keys for backends you enable)
SEARCH_BACKEND=web          # web | custom
TAVILY_API_KEY=your_tavily_api_key_here    # Get from app.tavily.com

# Storage (local by default)
REPORTS_DIR=./reports
SKILLS_DIR=./skills
AGENTS_DIR=./agents

# Encryption (for stored assessment documents)
ENCRYPTION_KEY=your_32_char_encryption_key_here
