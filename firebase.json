{
  "functions": [
    {
      "source": ".",
      "codebase": "default",
      "ignore": [
        "src/frontend/**",
        "src/frontend",
        "reports/**",
        "node_modules/**",
        ".git/**",
        "*.pen",
        "*.pdf",
        "*.pages",
        ".env*"
      ]
    }
  ],
  "hosting": {
    "public": "src/frontend/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**", "function": "api", "region": "us-central1" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
