                      "fontSize": 9,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "fJxnQ",
                      "fill": "#14532D",
                      "content": "runWithSearch(sessionId, system, prompt, label)",
                      "fontFamily": "Inter",
                      "fontSize": 9,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "7VaCH",
                      "fill": "#047857",
                      "content": "  1. client.messages.create() → Claude API call",
                      "fontFamily": "Inter",
                      "fontSize": 9,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "lqhsg",
                      "fill": "#047857",
                      "content": "  2. stop_reason === tool_use?",
                      "fontFamily": "Inter",
                      "fontSize": 9,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "5kr28",
                      "fill": "#047857",
                      "content": "     → execute web_search via Tavily",
                      "fontFamily": "Inter",
                      "fontSize": 9,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "YpFyy",
                      "fill": "#047857",
                      "content": "     → push tool_result → loop",
                      "fontFamily": "Inter",
                      "fontSize": 9,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "ntWcu",
                      "fill": "#047857",
                      "content": "  3. stop_reason === end_turn → return text",
                      "fontFamily": "Inter",
                      "fontSize": 9,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "U3kqm",
                      "fill": "#047857",
                      "content": "  4. trackTelemetry(): llmCalls · tokens · searches",
                      "fontFamily": "Inter",
                      "fontSize": 9,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "rectangle",
